modules = ["go-1.21", "bash", "python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "GONOSUMDB='*' go build -o kaptaan ./cmd/kaptaan && ./kaptaan"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["./kaptaan"]
build = ["bash", "-c", "GONOSUMDB='*' go build -o kaptaan ./cmd/kaptaan"]

[userenv]

[userenv.shared]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
