# ── Telegram ────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Database ─────────────────────────────────────────────────────────────────
# Postgres connection string
DATABASE_URL=postgres://user:password@localhost:5432/kaptaan?sslmode=disable

# ── LLM Providers (at least one required) ────────────────────────────────────
# DeepSeek API key — https://platform.deepseek.com
DEEPSEEK_API_KEY=

# NVIDIA NIM API keys (optional fallback providers)
NIM_API_KEY_1=
NIM_API_KEY_2=

# ── GitHub ───────────────────────────────────────────────────────────────────
# The repo the agent will build on (e.g. myorg/myrepo)
GITHUB_REPO=
# Personal access token with repo + PR permissions
GITHUB_TOKEN=

# ── Workspace ────────────────────────────────────────────────────────────────
# Local directory where the repo will be cloned (default: /tmp/kaptaan-workspace)
WORKSPACE_DIR=/tmp/kaptaan-workspace
