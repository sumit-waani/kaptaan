# ── LLM Provider (required) ──────────────────────────────────────────────────
# DeepSeek API key — https://platform.deepseek.com
# The pool uses DeepSeek-V4-Pro by default. The legacy "deepseek-chat" and
# "deepseek-reasoner" aliases are deprecated and quietly route to V4-Flash,
# so we pin the Pro tier explicitly.
DEEPSEEK_API_KEY=

# Optional model override (default: deepseek-v4-pro). Only set if you
# explicitly want a different model.
# DEEPSEEK_MODEL=deepseek-v4-pro

# ── Database (required) ──────────────────────────────────────────────────────
# Postgres connection string. On Replit this is provided automatically.
DATABASE_URL=

# ── E2B sandboxes (required for the Builder) ────────────────────────────────
# https://e2b.dev — used to spawn an isolated Linux sandbox for each builder
# job. Without this the Manager can plan but the Builder can't execute.
E2B_API_KEY=

# ── Notes ────────────────────────────────────────────────────────────────────
# GitHub repo + token are NOT environment variables anymore. They are stored
# per-project in the database and edited from the Settings tab in the UI.
# Each project carries its own repo and PAT.
